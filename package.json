{
  "name": "pterm",
  "version": "0.1.0",
  "description": "A cross-platform terminal multiplexer organized around projects",
  "author": "JT Turner <jtwebman@gmail.com>",
  "type": "module",
  "main": "dist/main/index.mjs",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsdown --config tsdown.main.config.ts",
    "build:preload": "tsdown --config tsdown.preload.config.ts",
    "build:renderer": "vite build",
    "test": "npm run build && npx playwright test",
    "test:headed": "npm run build && npx playwright test --headed",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "build": {
    "appId": "com.jtwebman.pterm",
    "productName": "pterm",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/node-pty/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "pacman",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "TerminalEmulator"
    },
    "publish": {
      "provider": "github",
      "owner": "jtwebman",
      "repo": "pterm"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.1",
    "tsdown": "^0.21.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  }
}
